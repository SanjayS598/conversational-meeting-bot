PORT=3001
NODE_ENV=development

# Shared internal auth between backend services
INTERNAL_SERVICE_SECRET=replace-me-with-a-long-random-secret

# Local service URLs
GEMINI_SERVICE_URL=http://localhost:3002
CONTROL_BACKEND_URL=http://localhost:3000
VOICE_SERVICE_URL=http://localhost:8083

# Recall.ai
RECALL_API_KEY=
RECALL_REGION=us-west-2

# Public HTTPS base URL that Recall.ai can reach for webhooks
# Example: https://your-tunnel.trycloudflare.com
RECALL_WEBHOOK_URL=

# Session defaults
MAX_CONCURRENT_SESSIONS=5
BOT_DISPLAY_NAME=Clairo

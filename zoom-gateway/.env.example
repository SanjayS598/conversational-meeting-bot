# Server config
PORT=3001

# Shared secret used by all internal services (generate with: openssl rand -hex 32)
INTERNAL_SERVICE_SECRET=replace-with-your-generated-secret

# URLs of the other services (adjust ports/hosts as needed)
GEMINI_SERVICE_URL=http://localhost:3002
VOICE_SERVICE_URL=http://localhost:3003
CONTROL_BACKEND_URL=http://localhost:3000

# Bot appearance inside the Zoom meeting
BOT_DISPLAY_NAME=AI Assistant

# Max simultaneous meeting sessions (project spec: 3)
MAX_CONCURRENT_SESSIONS=3

# Run Chrome in headless mode (set to false for local debugging)
HEADLESS=true

NODE_ENV=development

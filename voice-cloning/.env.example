PORT=8083
NODE_ENV=development

# Mandatory for real ElevenLabs cloning and TTS. Leave empty to run in mock mode.
ELEVENLABS_API_KEY=

# Shared secret between services.
INTERNAL_BACKEND_AUTH_TOKEN=replace-me-with-a-long-random-string

# Local service integrations
CONTROL_BACKEND_BASE_URL=http://localhost:3000
MEETING_GATEWAY_BASE_URL=http://localhost:3001

# Voice defaults
DEFAULT_TTS_MODEL=eleven_flash_v2_5
DEFAULT_OUTPUT_FORMAT=mp3_44100_128
DEFAULT_LANGUAGE_CODE=en
MAX_SPEECH_CHARACTERS=500
SPEECH_COOLDOWN_MS=5000

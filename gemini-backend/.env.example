# ─── Gemini / Google AI ───────────────────────────────────────────────────────
GEMINI_API_KEY=                    # Google AI Studio key (https://aistudio.google.com/app/apikey)

# ─── OpenAI Whisper STT ───────────────────────────────────────────────────────
OPENAI_API_KEY=                    # OpenAI API key (https://platform.openai.com/api-keys)
WHISPER_MODEL=whisper-1            # OpenAI Whisper model (whisper-1 is the only API model)

# ─── Internal Service Auth ────────────────────────────────────────────────────
INTERNAL_SERVICE_TOKEN=            # Shared secret used by all backend services

# ─── Control Backend ──────────────────────────────────────────────────────────
BACKEND_URL=http://localhost:4000   # Base URL of the Control Backend service

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379    # Redis connection string

# ─── ElevenLabs TTS (voice agent) ────────────────────────────────────────────
ELEVENLABS_API_KEY=                # ElevenLabs API key
ELEVENLABS_VOICE_ID=               # ElevenLabs voice ID to use for the agent

# ─── Zoom Gateway (for audio injection) ───────────────────────────────────────
ZOOM_GATEWAY_URL=http://localhost:3001

# ─── Voice Runtime ────────────────────────────────────────────────────────────
VOICE_RUNTIME_URL=http://localhost:5001  # ElevenLabs Voice Runtime base URL

# ─── Service ──────────────────────────────────────────────────────────────────
PORT=3001
LOG_LEVEL=info                     # debug | info | warning | error

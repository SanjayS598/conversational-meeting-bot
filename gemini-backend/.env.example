# Core model config
GEMINI_API_KEY=

# Optional STT providers
# The current meeting flow primarily ingests transcripts from Recall.ai.
# Keep these if you want to preserve the legacy/fallback raw-audio STT path.
DEEPGRAM_API_KEY=
OPENAI_API_KEY=
WHISPER_MODEL=whisper-1

# Shared internal auth
INTERNAL_SERVICE_TOKEN=replace-me-with-a-long-random-secret

# Service integrations
BACKEND_URL=http://localhost:3000
VOICE_RUNTIME_URL=http://localhost:8083
ZOOM_GATEWAY_URL=http://localhost:3001
REDIS_URL=redis://localhost:6379

# Optional voice defaults used by the backend voice path
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Service runtime
PORT=3002
LOG_LEVEL=info
